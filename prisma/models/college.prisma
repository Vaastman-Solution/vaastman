model College {
  id     String   @id @default(cuid())
  name   String
  code 	 String?
  fees   String
  domains Domain[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Domain {
  id       String    @id @default(cuid())
  name     String
  colleges College[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}